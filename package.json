{
  "name": "otica-saas",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "main": "index.js",
  "type": "module",
  "workspaces": [
    "app/client"
  ],
  "scripts": {
    "dev": "tsx watch app/server/server.ts",
    "dev:server": "tsx watch app/server/server.ts",
    "dev:client": "npm run dev --workspace @otica-saas/client -- --host 0.0.0.0",
    "dev-worker": "tsx watch app/server/queue/registry.ts",
    "db:migrate": "tsx app/server/database/migrate.ts",
    "db:rollback": "tsx app/server/database/rollback.ts",
    "db:seed": "tsx app/server/database/seed.ts",
    "build:client": "npm run build --workspace @otica-saas/client",
    "start:client": "npm run start --workspace @otica-saas/client",
    "typecheck": "npm run typecheck:server && npm run typecheck:client",
    "typecheck:server": "tsc --noEmit",
    "typecheck:client": "npm run typecheck --workspace @otica-saas/client"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@react-router/node": "7.16.0",
    "@react-router/serve": "7.16.0",
    "amqplib": "^2.0.1",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "isbot": "^5.1.36",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.16.0",
    "redis": "^6.0.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.16.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.3"
  }
}
